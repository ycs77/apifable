{
  "name": "apifable",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.2",
  "description": "Explore any OpenAPI spec and generate code from it. Built for AI agents.",
  "license": "MIT",
  "bin": {
    "apifable": "./bin/apifable.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "inspect": "npx -y @modelcontextprotocol/inspector node bin/apifable.js mcp --spec fixtures/openapi.yaml",
    "lint": "eslint . --cache --concurrency auto",
    "type-check": "tsc --noEmit",
    "release": "bumpp --commit \"Release v%s\"",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cac": "^6.7.14",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@ycs77/eslint-config": "^7.0.0",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.2",
    "tsdown": "^0.20.3",
    "typescript": "~5.9.3"
  }
}
