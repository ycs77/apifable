{
  "name": "apifable",
  "type": "module",
  "version": "1.1.1",
  "packageManager": "pnpm@10.32.1",
  "description": "MCP server that helps AI agents explore OpenAPI specs, search endpoints, and generate TypeScript types.",
  "license": "MIT",
  "homepage": "https://github.com/ycs77/apifable",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ycs77/apifable.git"
  },
  "keywords": [
    "openapi",
    "modelcontextprotocol",
    "mcp",
    "types",
    "typescript",
    "ai",
    "agent",
    "agentic",
    "llm",
    "api"
  ],
  "bin": {
    "apifable": "./bin/apifable.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "inspect": "npx -y @modelcontextprotocol/inspector node bin/apifable.js mcp",
    "lint": "eslint . --cache --concurrency auto",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "code-check": "pnpm lint && pnpm type-check && pnpm test --run",
    "release": "bumpp --commit \"Release v%s\"",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cac": "^6.7.14",
    "minisearch": "^7.2.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@ycs77/eslint-config": "^7.2.2",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "memfs": "^4.56.11",
    "tsdown": "^0.21.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
