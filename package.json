{
  "name": "openapi-agent",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.2",
  "description": "OpenAPI tools built for AI agents.",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "openapi-agent": "./bin/openapi-agent.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "inspect": "npx -y @modelcontextprotocol/inspector node bin/openapi-agent.js mcp --spec fixtures/openapi.yaml",
    "lint": "eslint . --cache --concurrency auto",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cac": "^6.7.14",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@ycs77/eslint-config": "^7.0.0",
    "eslint": "^9.39.2",
    "tsdown": "^0.20.3",
    "typescript": "~5.9.3"
  }
}
