{
  "name": "apifable",
  "version": "1.1.4",
  "description": "MCP server that helps AI agents explore OpenAPI specs, search endpoints, and generate TypeScript types.",
  "keywords": [
    "agent",
    "agentic",
    "ai",
    "api",
    "llm",
    "mcp",
    "modelcontextprotocol",
    "openapi",
    "types",
    "typescript"
  ],
  "homepage": "https://github.com/ycs77/apifable",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ycs77/apifable.git"
  },
  "bin": {
    "apifable": "./bin/apifable.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "inspect": "npx -y @modelcontextprotocol/inspector node bin/apifable.js mcp",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsc",
    "test": "vitest",
    "check": "pnpm lint && pnpm fmt --check && pnpm typecheck && pnpm test --run",
    "release": "bumpp --commit \"Release v%s\"",
    "prepare": "simple-git-hooks",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cac": "^7.0.0",
    "minisearch": "^7.2.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "bumpp": "^11.0.1",
    "lint-staged": "^16.4.0",
    "memfs": "^4.56.11",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "pnpm fmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm lint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
